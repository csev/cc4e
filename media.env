# Source before running media-util tools for CC4E:
#   source /Users/csev/htdocs/cc4e/media.env

# ---------------------------------------------------------------------------
# Per-course settings (edit these when copying for another course)
# ---------------------------------------------------------------------------
export COURSE_ROOT=/Users/csev/htdocs/cc4e
export MEDIA_ROOT=/Volumes/2026-05-5TB-A-Rsync/Desktop/teach/cc4e-media
export WHISPER_ROOT=/Users/csev/htdocs/cc4e/whisper
export YOUTUBE_DIR=/Users/csev/htdocs/cc4e/youtube
export YOUTUBE_PLAYLIST='https://www.youtube.com/playlist?list=PLlRFEj9H3Oj5NbaFb1b2n8lib01uNPWLa'
export COURSE_HINT='C Programming for Everybody, CC4E, C, UNIX, Kernighan, Ritchie, Dr. Chuck, Chuck Severance'
export EXTRA_TAGS='cc4e, cc4e-lecture'
export EXTRA_DESCRIPTION='For more materials, auto graders, and more courses, please see www.masterprogrammer.com.'

# Optional per-course overrides:
# export MODEL=$HOME/models/ggml-medium.bin
# export OLLAMA_MODEL=qwen3:4b

# ---------------------------------------------------------------------------
# Shared boilerplate (usually leave alone)
# ---------------------------------------------------------------------------
PWD_NOW="$(pwd -P)"

case "$PWD_NOW" in
  "$COURSE_ROOT"|"$COURSE_ROOT"/*) ;;
  *)
    echo "ERROR: media.env is for this course; pwd is $PWD_NOW" >&2
    echo "       expected under $COURSE_ROOT" >&2
    return 1 2>/dev/null || exit 1
    ;;
esac

export MEDIA_UTIL=/Users/csev/htdocs/media-util
case ":$PATH:" in
  *":$MEDIA_UTIL/bin:"*) ;;
  *) export PATH="$MEDIA_UTIL/bin:$PATH" ;;
esac

echo "media.env: ready (pwd=$PWD_NOW)"
